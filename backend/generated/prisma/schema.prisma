// PolyTalk Database Schema
// Version: 1.0
// Author: 工部严世蕃
// Date: 2026-03-04

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ==================== 用户系统 ====================

/// 用户表
model User {
  id             String    @id @default(uuid())
  username       String    @unique
  email          String?   @unique
  passwordHash   String?   @map("password_hash")
  displayName    String?   @map("display_name")
  avatarUrl      String?   @map("avatar_url")
  role           String    @default("student") // student, parent, teacher
  language       String    @default("zh-CN")
  preferredLangs String?   @map("preferred_langs") // JSON array
  settings       String? // JSON object
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  conversations Conversation[]
  progress      UserProgress[]
  vocabProgress UserVocabProgress[]

  @@map("users")
}

// ==================== 课程系统 ====================

/// 课程表
model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  language    String // en, ja, ko, fr, es
  level       String   @default("beginner") // beginner, intermediate, advanced
  category    String? // 启蒙, 职场, 旅游
  coverUrl    String?  @map("cover_url")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by")
  metadata    String? // JSON

  // Relations
  units         Unit[]
  vocabs        VocabItem[]
  conversations Conversation[]

  @@index([language])
  @@index([level])
  @@map("courses")
}

/// 单元表
model Unit {
  id          String   @id @default(uuid())
  courseId    String   @map("course_id")
  title       String
  description String?
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, orderIndex])
  @@map("units")
}

/// 课时表
model Lesson {
  id         String   @id @default(uuid())
  unitId     String   @map("unit_id")
  title      String
  content    String? // JSON/Markdown
  lessonType String   @default("dialogue") @map("lesson_type") // dialogue, vocabulary, grammar, quiz
  orderIndex Int      @map("order_index")
  duration   Int? // minutes
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  unit          Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  progress      UserProgress[]
  conversations Conversation[]

  @@index([unitId, orderIndex])
  @@map("lessons")
}

// ==================== 对话系统 ====================

/// 对话会话表
model Conversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courseId  String?  @map("course_id")
  lessonId  String?  @map("lesson_id")
  title     String?
  status    String   @default("active") // active, archived, deleted
  context   String? // JSON
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lesson   Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("conversations")
}

/// 消息表
model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String // user, assistant, system
  content        String
  audioUrl       String?  @map("audio_url")
  audioDuration  Float?   @map("audio_duration")
  metadata       String? // JSON
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ==================== 学习进度 ====================

/// 用户进度表
model UserProgress {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  lessonId     String    @map("lesson_id")
  completed    Boolean   @default(false)
  score        Int? // 0-100
  timeSpent    Int?      @map("time_spent") // seconds
  attempts     Int       @default(0)
  lastAccessed DateTime  @default(now()) @map("last_accessed")
  completedAt  DateTime? @map("completed_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("user_progress")
}

// ==================== 词汇系统 ====================

/// 词汇表
model VocabItem {
  id            String   @id @default(uuid())
  courseId      String   @map("course_id")
  word          String
  translation   String
  pronunciation String?
  audioUrl      String?  @map("audio_url")
  example       String?
  exampleAudio  String?  @map("example_audio")
  difficulty    Int      @default(1) // 1-5
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  course       Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userProgress UserVocabProgress[]

  @@index([courseId])
  @@index([word])
  @@map("vocab_items")
}

/// 用户词汇掌握表
model UserVocabProgress {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  vocabId      String    @map("vocab_id")
  masteryLevel Int       @default(0) @map("mastery_level") // 0-5
  correctCount Int       @default(0) @map("correct_count")
  wrongCount   Int       @default(0) @map("wrong_count")
  lastReviewed DateTime? @map("last_reviewed")
  nextReview   DateTime? @map("next_review")

  // Relations
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocab VocabItem @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabId])
  @@index([userId])
  @@index([nextReview])
  @@map("user_vocab_progress")
}
